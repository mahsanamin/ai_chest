#!/bin/bash
# Remove a git worktree and its associated branch
# Usage: aa_g_worktree_remove <name> [--verify] [--force] [--keep-remote]

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Parse arguments
FORCE_MODE=false
VERIFY_MODE=false
KEEP_REMOTE=false
FEATURE_NAME=""

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -f|--force) FORCE_MODE=true ;;
        -v|--verify) VERIFY_MODE=true ;;
        --keep-remote) KEEP_REMOTE=true ;;
        -h|--help)
            echo "Usage: aa_g_worktree_remove <name> [options]"
            echo ""
            echo "Remove a git worktree and its associated branch."
            echo ""
            echo "Arguments:"
            echo "  name              Name of the worktree to remove"
            echo ""
            echo "Options:"
            echo "  -v, --verify      Verify branch is merged into main before removing (safe)"
            echo "  -f, --force       Skip all checks and confirmations"
            echo "  --keep-remote     Don't delete the remote branch"
            echo "  -h, --help        Show this help"
            echo ""
            echo "Examples:"
            echo "  aa_g_worktree_remove feature/auth       # Remove with unpushed warning"
            echo "  aa_g_worktree_remove feature/auth -v    # Verify merged first (recommended)"
            echo "  aa_g_worktree_remove feature/auth -f    # Force remove, no checks"
            echo ""
            echo "Note: <name> matches either the worktree directory name or the"
            echo "branch checked out inside it. If a name matches multiple worktrees,"
            echo "the command aborts and lists candidates so you can disambiguate."
            exit 0
            ;;
        *) FEATURE_NAME="$1" ;;
    esac
    shift
done

if [ -z "$FEATURE_NAME" ]; then
    echo -e "${RED}Error: Worktree name is required${NC}"
    echo "Usage: aa_g_worktree_remove <name> [--verify] [--force]"
    echo "Run with --help for more options"
    exit 1
fi

# Check if in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    exit 1
fi

# Get main worktree and ensure we're there
CURRENT_DIR=$(git rev-parse --show-toplevel)
# Use --porcelain + substr extraction so worktree paths containing spaces survive
# (default `git worktree list` is space-separated; awk '{print $1}' would truncate
# "/Users/me/My Repos/foo" at "/Users/me/My").
MAIN_WORKTREE=$(git worktree list --porcelain | awk '/^worktree / {print substr($0, 10)}' | head -n 1)

if [ "$CURRENT_DIR" != "$MAIN_WORKTREE" ]; then
    echo -e "${YELLOW}Switching to main repository...${NC}"
    cd "$MAIN_WORKTREE" || exit 1
fi

GIT_ROOT="$MAIN_WORKTREE"
PROJECT_NAME=$(basename "$GIT_ROOT")

# Determine main branch
if git show-ref --verify --quiet refs/heads/main; then
    MAIN_BRANCH="main"
elif git show-ref --verify --quiet refs/heads/master; then
    MAIN_BRANCH="master"
else
    echo -e "${RED}Error: Neither 'main' nor 'master' branch found${NC}"
    exit 1
fi

# Resolve worktree by directory name OR branch name.
# Match against:
#   - basename of the worktree path (exact and slash-to-dash forms)
#   - branch checked out inside the worktree (refs/heads/ stripped)
# Skip the main worktree (never removable here).
WORKTREES_DIR="$(dirname "$GIT_ROOT")/WorkTrees"
SLASH_TO_DASH="${FEATURE_NAME//\//-}"

# Merge path + branch + reason into single delimited array so the loop works in
# both bash (0-indexed) and zsh (1-indexed by default). Pure element iteration
# avoids ${!ARR[@]} (bash-only) and ${ARR[$i]} (indexing diverges between shells).
# TAB is a safe delimiter — git refuses TABs in branch/path names.
TAB=$'\t'
CANDIDATES=()

wt_path=""
wt_branch=""
while IFS= read -r line; do
    if [[ "$line" == "worktree "* ]]; then
        wt_path="${line#worktree }"
        wt_branch=""
    elif [[ "$line" == "branch "* ]]; then
        wt_branch="${line#branch }"
        wt_branch="${wt_branch#refs/heads/}"
    elif [[ -z "$line" && -n "$wt_path" ]]; then
        if [ "$wt_path" != "$MAIN_WORKTREE" ]; then
            wt_dir=$(basename "$wt_path")
            reason=""
            if [ "$wt_dir" = "$FEATURE_NAME" ] || [ "$wt_dir" = "$SLASH_TO_DASH" ]; then
                reason="directory"
            fi
            if [ -n "$wt_branch" ] && [ "$wt_branch" = "$FEATURE_NAME" ]; then
                if [ -z "$reason" ]; then
                    reason="branch"
                else
                    reason="directory and branch"
                fi
            fi
            if [ -n "$reason" ]; then
                CANDIDATES+=("${wt_path}${TAB}${wt_branch}${TAB}${reason}")
            fi
        fi
        wt_path=""
        wt_branch=""
    fi
done < <(git worktree list --porcelain; echo)

n_candidates=${#CANDIDATES[@]}
if [ "$n_candidates" -eq 0 ]; then
    echo -e "${RED}Error: Worktree not found${NC}"
    echo ""
    echo "Available worktrees:"
    git worktree list
    exit 1
elif [ "$n_candidates" -gt 1 ]; then
    echo -e "${RED}Error: '$FEATURE_NAME' matches multiple worktrees${NC}"
    echo ""
    for entry in "${CANDIDATES[@]}"; do
        path="${entry%%${TAB}*}"
        rest="${entry#*${TAB}}"
        branch="${rest%%${TAB}*}"
        rsn="${rest#*${TAB}}"
        echo "  • $path  [branch: ${branch:-<detached>}, matched by: $rsn]"
    done
    echo ""
    echo "Disambiguate by passing the full directory name."
    exit 1
fi

# Single match — extract path and branch from the only entry
WORKTREE_PATH=""
BRANCH_NAME=""
for entry in "${CANDIDATES[@]}"; do
    WORKTREE_PATH="${entry%%${TAB}*}"
    rest="${entry#*${TAB}}"
    BRANCH_NAME="${rest%%${TAB}*}"
done

if [ -z "$BRANCH_NAME" ]; then
    echo -e "${YELLOW}Warning: Could not detect branch name${NC}"
fi

# Protected branches
PROTECTED_BRANCHES="main master staging develop development prod production"
for protected in $PROTECTED_BRANCHES; do
    if [ "$BRANCH_NAME" = "$protected" ]; then
        echo -e "${RED}Error: Cannot delete protected branch '$BRANCH_NAME'${NC}"
        exit 1
    fi
done

echo -e "${BLUE}Worktree:${NC}     $WORKTREE_PATH"
echo -e "${BLUE}Branch:${NC}       $BRANCH_NAME"
echo -e "${BLUE}Main branch:${NC}  $MAIN_BRANCH"
echo ""

# Fetch latest
echo "Fetching latest from remote..."
git fetch origin "$MAIN_BRANCH" --quiet 2>/dev/null || true

#############################
# VERIFY MODE: Check if merged
#############################
if [ "$VERIFY_MODE" = true ] && [ -n "$BRANCH_NAME" ]; then
    # Check if branch is merged into main
    IS_MERGED=false

    # Method 1: git branch --merged
    MERGED_BRANCHES=$(git branch --merged "$MAIN_BRANCH" 2>/dev/null | sed 's/^[ *]*//')
    if echo "$MERGED_BRANCHES" | grep -qx "$BRANCH_NAME"; then
        IS_MERGED=true
    fi

    # Method 2: Check against origin/main
    if [ "$IS_MERGED" = false ]; then
        MERGED_REMOTE=$(git branch --merged "origin/$MAIN_BRANCH" 2>/dev/null | sed 's/^[ *]*//')
        if echo "$MERGED_REMOTE" | grep -qx "$BRANCH_NAME"; then
            IS_MERGED=true
        fi
    fi

    # Method 3: Check if branch tip is ancestor
    if [ "$IS_MERGED" = false ]; then
        BRANCH_TIP=$(git rev-parse "$BRANCH_NAME" 2>/dev/null)
        MERGE_BASE=$(git merge-base "$BRANCH_NAME" "origin/$MAIN_BRANCH" 2>/dev/null)
        if [ "$BRANCH_TIP" = "$MERGE_BASE" ]; then
            IS_MERGED=true
        fi
    fi

    # Method 4: No code diff (squash merge)
    if [ "$IS_MERGED" = false ]; then
        if git diff --quiet "origin/$MAIN_BRANCH"..."$BRANCH_NAME" 2>/dev/null; then
            echo -e "${YELLOW}(Detected as squash merge - no code differences)${NC}"
            IS_MERGED=true
        fi
    fi

    if [ "$IS_MERGED" = false ]; then
        MERGE_BASE=$(git merge-base "$BRANCH_NAME" "origin/$MAIN_BRANCH" 2>/dev/null)
        MAIN_CHANGES=$(git rev-list "$MERGE_BASE".."origin/$MAIN_BRANCH" --count 2>/dev/null || echo "0")

        if [ "$MAIN_CHANGES" -gt 0 ] 2>/dev/null; then
            echo -e "${YELLOW}Branch may have been squash-merged, but main has moved forward.${NC}"
            echo ""

            # Try ticket verification
            TICKET_VERIFIED=false
            BRANCH_COMMITS=$(git log --oneline "$MERGE_BASE".."$BRANCH_NAME" 2>/dev/null)
            TICKETS=$(echo "$BRANCH_COMMITS" | grep -oE '[A-Z]{2,}-[0-9]+' | sort -u || true)

            if [ -n "$TICKETS" ]; then
                echo -e "${BLUE}Checking tickets in main...${NC}"
                for ticket in $TICKETS; do
                    FOUND=$(git log "origin/$MAIN_BRANCH" --oneline --grep="$ticket" 2>/dev/null | head -1)
                    if [ -n "$FOUND" ]; then
                        echo -e "${GREEN}✓ Found '$ticket' in main:${NC} $FOUND"
                        TICKET_VERIFIED=true
                    fi
                done
                echo ""
            fi

            if [ "$TICKET_VERIFIED" = true ]; then
                echo -e "${GREEN}✓ Ticket verified - safe to delete${NC}"
                IS_MERGED=true
            else
                echo -e "${BLUE}Your branch commits:${NC}"
                git log --oneline "$MERGE_BASE".."$BRANCH_NAME" | head -5
                echo ""
                echo -e "${BLUE}Main has ${MAIN_CHANGES} new commits since divergence.${NC}"
                echo ""
                echo -e "${BLUE}Differences:${NC}"
                git diff "origin/$MAIN_BRANCH"..."$BRANCH_NAME" --stat | head -15
                echo ""

                if [ "$FORCE_MODE" = false ]; then
                    echo -e "${YELLOW}Could not auto-verify. Options:${NC}"
                    echo ""
                    echo "  [r] Rebase onto main and check again (recommended)"
                    echo "  [d] Delete anyway"
                    echo "  [c] Cancel"
                    echo ""
                    # Single-keypress prompt — preserves the UX from before the
                    # zsh-compat fix that switched to plain `read -r`. zsh's
                    # `read -k 1` and bash's `read -n 1` aren't interchangeable.
                    if [ -n "$ZSH_VERSION" ]; then
                        printf "Choice [r/d/c]: "; read -k 1 REPLY; echo
                    else
                        read -p "Choice [r/d/c]: " -n 1 -r REPLY; echo
                    fi

                    if [[ $REPLY =~ ^[Rr]$ ]]; then
                        echo ""
                        echo "Rebasing onto origin/$MAIN_BRANCH..."
                        cd "$WORKTREE_PATH" || exit 1

                        if git rebase "origin/$MAIN_BRANCH" 2>/dev/null; then
                            COMMITS_AFTER=$(git rev-list "origin/$MAIN_BRANCH"..HEAD --count 2>/dev/null)
                            cd "$GIT_ROOT" || exit 1

                            if [ "$COMMITS_AFTER" = "0" ]; then
                                echo -e "${GREEN}✓ No unique commits remain - was squash-merged${NC}"
                                IS_MERGED=true
                            else
                                echo -e "${YELLOW}$COMMITS_AFTER unique commit(s) remain (NOT in main)${NC}"
                                if [ -n "$ZSH_VERSION" ]; then
                                    printf "Still delete? (y/N): "; read -k 1 REPLY; echo
                                else
                                    read -p "Still delete? (y/N): " -n 1 -r REPLY; echo
                                fi
                                if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                                    echo "Cancelled."
                                    exit 0
                                fi
                            fi
                        else
                            git rebase --abort 2>/dev/null
                            cd "$GIT_ROOT" || exit 1
                            echo -e "${RED}Rebase failed - branch has conflicts with main${NC}"
                            exit 1
                        fi
                    elif [[ $REPLY =~ ^[Dd]$ ]]; then
                        echo "Proceeding..."
                    else
                        echo "Cancelled."
                        exit 0
                    fi
                fi
            fi
        else
            echo -e "${RED}ERROR: Branch '$BRANCH_NAME' is NOT merged into $MAIN_BRANCH${NC}"
            echo ""
            git log --oneline "$MAIN_BRANCH..$BRANCH_NAME" | head -10
            echo ""
            if [ "$FORCE_MODE" = false ]; then
                echo "Use --force to delete anyway."
                exit 1
            fi
        fi
    else
        echo -e "${GREEN}✓ Branch is merged into $MAIN_BRANCH${NC}"
    fi

#############################
# NON-VERIFY MODE: Check unpushed
#############################
elif [ "$VERIFY_MODE" = false ] && [ -n "$BRANCH_NAME" ] && [ "$FORCE_MODE" = false ]; then
    # Check for unpushed commits
    REMOTE_NAME=$(git config "branch.$BRANCH_NAME.remote" 2>/dev/null || true)
    REMOTE_BRANCH=$(git config "branch.$BRANCH_NAME.merge" 2>/dev/null | sed 's|^refs/heads/||' || true)

    UNPUSHED_WARNING=false
    if [ -z "$REMOTE_NAME" ] || [ -z "$REMOTE_BRANCH" ]; then
        UNPUSHED_WARNING=true
        UNPUSHED_REASON="Branch has never been pushed to remote"
    elif git show-ref --verify --quiet "refs/remotes/$REMOTE_NAME/$REMOTE_BRANCH"; then
        UNPUSHED_COUNT=$(git rev-list "$REMOTE_NAME/$REMOTE_BRANCH..$BRANCH_NAME" --count 2>/dev/null || echo "0")
        if [ "$UNPUSHED_COUNT" -gt 0 ]; then
            UNPUSHED_WARNING=true
            UNPUSHED_REASON="Branch has $UNPUSHED_COUNT unpushed commit(s)"
        fi
    fi

    if [ "$UNPUSHED_WARNING" = true ]; then
        echo -e "${RED}⚠️  WARNING: $UNPUSHED_REASON${NC}"
        echo ""
        if [ -n "$ZSH_VERSION" ]; then
            printf "Delete anyway? (y/N): "; read -k 1 REPLY; echo
        else
            read -p "Delete anyway? (y/N): " -n 1 -r REPLY; echo
        fi
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Cancelled. Push first or use --force."
            exit 0
        fi
    fi
fi

#############################
# CONFIRMATION
#############################
if [ "$FORCE_MODE" = false ]; then
    echo ""
    echo -e "${YELLOW}Will remove:${NC}"
    echo "  • Worktree: $WORKTREE_PATH"
    echo "  • Local branch: $BRANCH_NAME"
    if [ "$VERIFY_MODE" = true ] && [ "$KEEP_REMOTE" = false ]; then
        echo "  • Remote branch: origin/$BRANCH_NAME"
    fi
    echo ""
    if [ -n "$ZSH_VERSION" ]; then
        printf "Proceed? (y/N): "; read -k 1 REPLY; echo
    else
        read -p "Proceed? (y/N): " -n 1 -r REPLY; echo
    fi
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        exit 0
    fi
fi

#############################
# Dirty working tree check
#############################
# `git worktree remove` without --force already refuses on a dirty tree; we
# only pass --force when the user has explicitly accepted data loss (or asked
# for it via --force on the command line). This keeps git's own safety net in
# play by default and gives the user a chance to back out.
USE_FORCE=false
if [ "$FORCE_MODE" = true ]; then
    USE_FORCE=true
elif [ -d "$WORKTREE_PATH" ]; then
    DIRTY_STATUS=$(git -C "$WORKTREE_PATH" status --porcelain 2>/dev/null || true)
    if [ -n "$DIRTY_STATUS" ]; then
        echo ""
        echo -e "${RED}⚠️  WARNING: Worktree has uncommitted changes${NC}"
        echo ""
        echo "$DIRTY_STATUS"
        echo ""
        echo -e "${YELLOW}These changes will be permanently lost if you proceed.${NC}"
        echo ""
        if [ -n "$ZSH_VERSION" ]; then
            printf "Discard uncommitted changes and remove anyway? (y/N): "; read -k 1 REPLY; echo
        else
            read -p "Discard uncommitted changes and remove anyway? (y/N): " -n 1 -r REPLY; echo
        fi
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Cancelled. Commit, stash, or re-run with --force to discard."
            exit 0
        fi
        USE_FORCE=true
    fi
fi

#############################
# DELETE
#############################
echo ""
echo "Removing worktree..."
if [ "$USE_FORCE" = true ]; then
    git worktree remove "$WORKTREE_PATH" --force
else
    git worktree remove "$WORKTREE_PATH"
fi
echo -e "${GREEN}✓ Worktree removed${NC}"

if [ -n "$BRANCH_NAME" ]; then
    echo "Deleting local branch..."
    git branch -D "$BRANCH_NAME" 2>/dev/null && echo -e "${GREEN}✓ Local branch deleted${NC}" || echo -e "${YELLOW}  (already deleted)${NC}"

    # Delete remote only in verify mode (unless --keep-remote)
    if [ "$VERIFY_MODE" = true ] && [ "$KEEP_REMOTE" = false ]; then
        echo "Deleting remote branch..."
        git push origin --delete "$BRANCH_NAME" 2>/dev/null && echo -e "${GREEN}✓ Remote branch deleted${NC}" || echo -e "${YELLOW}  (not found or already deleted)${NC}"
    fi
fi

echo ""
echo -e "${GREEN}✓ Done!${NC}"
