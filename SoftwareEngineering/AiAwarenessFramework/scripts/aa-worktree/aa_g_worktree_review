#!/bin/bash
# NOTE: This script is sourced (not executed) by the wrapper in worktree.sh
# so that cd works. Use 'return' instead of 'exit' to avoid killing the terminal.
#
# Creates a "review" worktree from a GitHub PR or a remote branch. The local
# branch is prefixed with 'review-' so it can't be confused with your own work.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

INPUT=""
REMOTE="origin"

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -r|--remote)
            if [ -z "${2:-}" ] || [[ "$2" == -* ]]; then
                echo "Error: -r/--remote requires a remote name"
                return 1
            fi
            REMOTE="$2"; shift ;;
        -h|--help)
            echo "Usage: aa_g_worktree_review <pr-number | branch-name> [-r|--remote <remote>]"
            echo ""
            echo "Creates a review worktree from a GitHub PR or remote branch."
            echo "The local branch is prefixed with 'review-' so it's clearly"
            echo "separate from your own work."
            echo ""
            echo "Arguments:"
            echo "  pr-number       A numeric PR number (looked up via gh CLI)"
            echo "  branch-name     Name of an existing branch on the remote"
            echo ""
            echo "Options:"
            echo "  -r, --remote    Remote to fetch from (default: origin)"
            echo "  -h, --help      Show this help message"
            echo ""
            echo "Examples:"
            echo "  aa_g_worktree_review 356                # from PR #356"
            echo "  aa_g_worktree_review fix/login-bug      # from origin/fix/login-bug"
            echo "  aa_g_worktree_review fix/x -r upstream  # from upstream/fix/x"
            echo ""
            echo "Cleanup:"
            echo "  aa_g_worktree_remove review-pr-356"
            echo "  aa_g_worktree_remove review-fix-login-bug"
            return 0
            ;;
        *) INPUT="$1" ;;
    esac
    shift
done

if [ -z "$INPUT" ]; then
    echo -e "${RED}Error: Provide a PR number or branch name${NC}"
    echo "Usage: aa_g_worktree_review <pr-number | branch-name>"
    return 1
fi

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    return 1
fi

GIT_ROOT=$(git rev-parse --show-toplevel)
PROJECT_NAME=$(basename "$GIT_ROOT")
WORKTREES_DIR="$(dirname "$GIT_ROOT")/WorkTrees"

# Decide whether the input is a PR number or a branch name
if [[ "$INPUT" =~ ^[0-9]+$ ]]; then
    if ! command -v gh > /dev/null 2>&1; then
        echo -e "${RED}Error: 'gh' CLI is required to look up PRs${NC}"
        echo "Install: https://cli.github.com/  — or pass the branch name directly."
        return 1
    fi
    PR_NUMBER="$INPUT"
    echo -e "${YELLOW}Looking up PR #$PR_NUMBER...${NC}"
    REMOTE_BRANCH=$(gh pr view "$PR_NUMBER" --json headRefName -q .headRefName 2>/dev/null)
    if [ -z "$REMOTE_BRANCH" ]; then
        echo -e "${RED}Error: Could not look up PR #$PR_NUMBER${NC}"
        echo "Check that the PR exists and you're authenticated: gh auth status"
        return 1
    fi
    PR_STATE=$(gh pr view "$PR_NUMBER" --json state -q .state 2>/dev/null)
    LOCAL_BRANCH="review-pr-$PR_NUMBER"
    WORKTREE_DIR_NAME="review-pr-$PR_NUMBER"
    echo -e "${BLUE}PR #$PR_NUMBER -> $REMOTE/$REMOTE_BRANCH  (state: ${PR_STATE:-UNKNOWN})${NC}"

    # Warn (but don't block) if the PR is closed or merged. Reviewing the final
    # state of a closed PR is legitimate; the user just needs to know what they're
    # checking out.
    if [ "$PR_STATE" = "MERGED" ] || [ "$PR_STATE" = "CLOSED" ]; then
        echo -e "${YELLOW}Note: PR #$PR_NUMBER is $PR_STATE.${NC}"
        echo "  - MERGED → the branch may have been deleted from the remote; fetch will fail if so."
        echo "  - CLOSED → no longer under review; you're checking out its final state."
        # Single-keypress prompt, consistent with aa_g_worktree_remove (see
        # commit 5e9b7a3). zsh's `read -k 1` and bash's `read -n 1` aren't
        # interchangeable, so branch on $ZSH_VERSION.
        if [ -n "$ZSH_VERSION" ]; then
            printf "  Proceed anyway? [y/N] "; read -k 1 REPLY; echo
        else
            read -p "  Proceed anyway? [y/N] " -n 1 -r REPLY; echo
        fi
        if ! [[ "$REPLY" =~ ^[Yy]$ ]]; then
            echo "Cancelled."
            return 0
        fi
    fi
else
    REMOTE_BRANCH="$INPUT"
    SANITIZED="${INPUT//\//-}"
    LOCAL_BRANCH="review-$SANITIZED"
    WORKTREE_DIR_NAME="review-$SANITIZED"
fi

WORKTREE_PATH="$WORKTREES_DIR/$PROJECT_NAME/$WORKTREE_DIR_NAME"

if [ -d "$WORKTREE_PATH" ]; then
    echo -e "${RED}Error: Review worktree already exists at $WORKTREE_PATH${NC}"
    echo "Remove it first: aa_g_worktree_remove $WORKTREE_DIR_NAME"
    return 1
fi

if git show-ref --verify --quiet "refs/heads/$LOCAL_BRANCH"; then
    echo -e "${RED}Error: Local branch '$LOCAL_BRANCH' already exists${NC}"
    echo "Remove it first: aa_g_worktree_remove $WORKTREE_DIR_NAME"
    return 1
fi

echo -e "${YELLOW}Fetching $REMOTE/$REMOTE_BRANCH...${NC}"
if ! git fetch "$REMOTE" "$REMOTE_BRANCH" 2>/dev/null; then
    echo -e "${RED}Error: Could not fetch $REMOTE/$REMOTE_BRANCH${NC}"
    return 1
fi

if ! git show-ref --verify --quiet "refs/remotes/$REMOTE/$REMOTE_BRANCH"; then
    echo -e "${RED}Error: $REMOTE/$REMOTE_BRANCH does not exist after fetch${NC}"
    return 1
fi

echo -e "${BLUE}Creating review worktree:${NC}"
echo "  Project:       $PROJECT_NAME"
echo "  Remote branch: $REMOTE/$REMOTE_BRANCH"
echo "  Local branch:  $LOCAL_BRANCH"
echo "  Path:          $WORKTREE_PATH"
echo ""

mkdir -p "$WORKTREES_DIR/$PROJECT_NAME"

git worktree add -b "$LOCAL_BRANCH" "$WORKTREE_PATH" "$REMOTE/$REMOTE_BRANCH"

if [ $? -eq 0 ]; then
    echo ""
    echo -e "${GREEN}✓ Review worktree created${NC}"

    DOTFILES_COPIED=0
    for dotfile in "$GIT_ROOT"/.*; do
        basename="$(basename "$dotfile")"
        if [[ "$basename" == "." || "$basename" == ".." || "$basename" == ".git" ]]; then
            continue
        fi
        cp -Rn "$dotfile" "$WORKTREE_PATH/" 2>/dev/null
        DOTFILES_COPIED=$((DOTFILES_COPIED + 1))
    done
    if [ $DOTFILES_COPIED -gt 0 ]; then
        echo -e "${GREEN}✓ Copied $DOTFILES_COPIED dotfile(s) to worktree${NC}"
    fi

    echo ""

    if [[ "${BASH_SOURCE[0]}" != "${0}" ]] || [[ -n "$ZSH_EVAL_CONTEXT" && "$ZSH_EVAL_CONTEXT" =~ :file$ ]]; then
        cd "$WORKTREE_PATH" || return 1
        echo -e "${GREEN}✓ Changed to worktree directory${NC}"
    else
        echo -e "${BLUE}To change to the worktree directory, run:${NC}"
        echo "  cd $WORKTREE_PATH"
    fi

    echo ""
    echo -e "${BLUE}To remove this review worktree later:${NC}"
    echo "  aa_g_worktree_remove $WORKTREE_DIR_NAME"
else
    echo -e "${RED}Failed to create review worktree${NC}"
    return 1
fi
