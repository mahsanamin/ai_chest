#!/bin/bash
# NOTE: This script is sourced (not executed) by the wrapper in worktree.sh
# so that cd works. Use 'return' instead of 'exit' to avoid killing the terminal.

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default base branch
BASE_BRANCH=""

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -b|--base) BASE_BRANCH="$2"; shift ;;
        -h|--help)
            echo "Usage: aa_g_worktree_init <branch-name> [-b|--base <branch>]"
            echo ""
            echo "Creates a git worktree. <branch-name> can be:"
            echo "  • a new branch (created from --base / story-picker / current / main)"
            echo "  • an existing local branch (checked out as-is)"
            echo "  • a branch that only exists on origin (auto-detected after fetch;"
            echo "    a local tracking branch is created from origin/<name>)"
            echo ""
            echo "Arguments:"
            echo "  branch-name     Name of the branch (new or existing, local or remote)"
            echo ""
            echo "Options:"
            echo "  -b, --base      Base branch for NEW branches (skips the picker)."
            echo "                  When omitted and the branch is new, the script collects"
            echo "                  candidate bases: main/master, current non-main branch,"
            echo "                  every local 'story/*' branch. Single candidate → silent;"
            echo "                  multiple → numbered picker. Ignored when <branch-name>"
            echo "                  already exists locally or on origin."
            echo "  -h, --help      Show this help message"
            echo ""
            echo "Examples:"
            echo "  aa_g_worktree_init feature/auth-improvements          # new branch from main"
            echo "  aa_g_worktree_init my-feature -b develop              # new branch from develop"
            echo "  aa_g_worktree_init feature/teammates-pr               # auto-checkout from origin"
            return 0
            ;;
        *) FEATURE_NAME="$1" ;;
    esac
    shift
done

# Check if branch name is provided
if [ -z "$FEATURE_NAME" ]; then
    echo -e "${RED}Error: Branch name is required${NC}"
    echo "Usage: aa_g_worktree_init <branch-name> [-b|--base <branch>]"
    echo "Example: aa_g_worktree_init feature/setup-local-data-seeds"
    return 1
fi

# Check if current directory is in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    echo "Run this command from within a git repository"
    return 1
fi

# Get the current worktree's toplevel (still useful for some operations).
GIT_ROOT=$(git rev-parse --show-toplevel)

# Derive the MAIN repo root from the git common dir. When invoked from inside a
# linked worktree, --show-toplevel points at the worktree (which would nest new
# worktrees as …/WorkTrees/<proj>/WorkTrees/<proj>/<new>). The common dir always
# resolves to the main checkout's .git, so its parent is the main repo root.
# Note: --git-common-dir can be relative (a bare ".git"), so resolve it via cd.
GIT_COMMON_DIR=$(git rev-parse --git-common-dir)
MAIN_ROOT=$(cd "$(dirname "$GIT_COMMON_DIR")" && pwd)
PROJECT_NAME=$(basename "$MAIN_ROOT")

# Construct the worktree path. WorkTrees lives alongside the main repo (sibling
# of MAIN_ROOT), so new worktrees land in <repos>/WorkTrees/<proj>/<branch> — a
# sibling of the current worktree, never nested as …/WorkTrees/<proj>/WorkTrees/…
WORKTREES_DIR="$(dirname "$MAIN_ROOT")/WorkTrees"
# Branch keeps original name (slashes allowed), directory name converts slashes to dashes
BRANCH_NAME="$FEATURE_NAME"
WORKTREE_DIR_NAME="${FEATURE_NAME//\//-}"
WORKTREE_PATH="$WORKTREES_DIR/$PROJECT_NAME/$WORKTREE_DIR_NAME"

# No-op guard: if we're already inside the linked worktree for this exact branch,
# there's nothing to create — short-circuit before any fetch/prompt. Detect
# "inside a linked worktree" robustly: either ".git" is a FILE (gitdir pointer)
# or the resolved git-dir lives under a /worktrees/ path. Only short-circuit on
# an exact branch match.
CURRENT_HEAD_BRANCH=$(git symbolic-ref --short -q HEAD || true)
IN_LINKED_WORKTREE=false
if [ -f "$GIT_ROOT/.git" ]; then
    IN_LINKED_WORKTREE=true
elif [[ "$(git rev-parse --git-dir 2>/dev/null)" == */worktrees/* ]]; then
    IN_LINKED_WORKTREE=true
fi
if [ "$IN_LINKED_WORKTREE" = true ] && [ -n "$CURRENT_HEAD_BRANCH" ] && [ "$CURRENT_HEAD_BRANCH" = "$BRANCH_NAME" ]; then
    echo -e "${YELLOW}Already on this branch's worktree ($BRANCH_NAME) — nothing to do.${NC}"
    return 0
fi

# Check if worktree already exists
if [ -d "$WORKTREE_PATH" ]; then
    echo -e "${RED}Error: Worktree already exists at $WORKTREE_PATH${NC}"
    return 1
fi

# Fetch first so we can detect branches that only exist on origin.
# We need both: the requested branch (in case it's a remote-only branch) and
# the base branch (in case we'll create a new branch from it).
echo -e "${YELLOW}Fetching latest from remote...${NC}"
git fetch origin "$BRANCH_NAME" 2>/dev/null || true
[ -n "$BASE_BRANCH" ] && git fetch origin "$BASE_BRANCH" 2>/dev/null || true

# Decide how to materialize the branch:
#   existing-local  -> branch already in this repo, just check it out
#   existing-remote -> branch only on origin, create local tracking branch
#   new             -> branch nowhere yet, create from BASE_BRANCH
if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo -e "${YELLOW}Branch $BRANCH_NAME already exists locally${NC}"
    printf "Use existing branch? (y/N): "
    read -r REPLY
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        return 0
    fi
    BRANCH_MODE="existing-local"
    BRANCH_SOURCE="$BRANCH_NAME (local)"
elif git show-ref --verify --quiet "refs/remotes/origin/$BRANCH_NAME"; then
    echo -e "${YELLOW}Branch $BRANCH_NAME exists on origin (not locally yet)${NC}"
    printf "Check out origin/%s in the new worktree? [Y/n] " "$BRANCH_NAME"
    read -r REPLY
    if [[ -z "$REPLY" || "$REPLY" =~ ^[Yy] ]]; then
        BRANCH_MODE="existing-remote"
        BRANCH_SOURCE="origin/$BRANCH_NAME"
    else
        echo "Cancelled."
        return 0
    fi
else
    BRANCH_MODE="new"
    # For a new branch, resolve BASE_BRANCH if it wasn't passed explicitly.
    # Collect candidates (current non-main + story/* branches), use a numbered
    # picker when there are multiple; silent default when single; explicit -b
    # always wins (we wouldn't be here if it was set).
    if [ -z "$BASE_BRANCH" ]; then
        DEFAULT_BASE=""
        if git show-ref --verify --quiet refs/heads/main; then
            DEFAULT_BASE="main"
        elif git show-ref --verify --quiet refs/heads/master; then
            DEFAULT_BASE="master"
        fi

        CURRENT_BRANCH=$(git symbolic-ref --short -q HEAD || true)
        CURRENT_IS_NONMAIN=false
        if [ -n "$CURRENT_BRANCH" ] && [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ]; then
            CURRENT_IS_NONMAIN=true
        fi

        # Merge value + label into a single array (each entry = "value<TAB>label").
        # Pure element iteration works in both bash and zsh; "${!ARR[@]}" and
        # "${ARR[$i]}" do NOT (bash-only / zsh-1-indexed differences). TAB is a
        # safe delimiter — git branch names can't contain it.
        TAB=$'\t'
        CHOICES=()

        if [ "$CURRENT_IS_NONMAIN" = true ]; then
            CHOICES+=("${CURRENT_BRANCH}${TAB}${CURRENT_BRANCH} (current branch, default)")
            if [ -n "$DEFAULT_BASE" ]; then
                CHOICES+=("${DEFAULT_BASE}${TAB}${DEFAULT_BASE}")
            fi
        elif [ -n "$DEFAULT_BASE" ]; then
            CHOICES+=("${DEFAULT_BASE}${TAB}${DEFAULT_BASE} (default)")
        fi

        # Append every local story/* branch that isn't already in CHOICES.
        while IFS= read -r br; do
            [ -z "$br" ] && continue
            dup=false
            for entry in "${CHOICES[@]}"; do
                value="${entry%%${TAB}*}"
                [ "$value" = "$br" ] && dup=true && break
            done
            if [ "$dup" = false ]; then
                CHOICES+=("${br}${TAB}${br}")
            fi
        done < <(git for-each-ref --format='%(refname:short)' refs/heads/story/ 2>/dev/null)

        n_choices=${#CHOICES[@]}
        if [ "$n_choices" -eq 0 ]; then
            echo -e "${RED}Error: Could not determine base branch${NC}"
            echo "Please specify base branch with -b option"
            return 1
        elif [ "$n_choices" -eq 1 ]; then
            for entry in "${CHOICES[@]}"; do
                BASE_BRANCH="${entry%%${TAB}*}"
            done
        else
            echo -e "${YELLOW}Base branch for the new worktree:${NC}"
            num=0
            for entry in "${CHOICES[@]}"; do
                num=$((num + 1))
                label="${entry#*${TAB}}"
                echo "  [$num] $label"
            done
            # printf + read works in both bash and zsh; read -r -p is bash-only.
            printf "Choose (1-%d, default 1): " "$n_choices"
            read -r REPLY
            REPLY="${REPLY:-1}"
            if ! [[ "$REPLY" =~ ^[0-9]+$ ]] || [ "$REPLY" -lt 1 ] || [ "$REPLY" -gt "$n_choices" ]; then
                echo -e "${RED}Invalid choice. Cancelled.${NC}"
                return 1
            fi
            num=0
            for entry in "${CHOICES[@]}"; do
                num=$((num + 1))
                if [ "$num" = "$REPLY" ]; then
                    BASE_BRANCH="${entry%%${TAB}*}"
                    break
                fi
            done
        fi
    fi

    # Verify base branch exists
    if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH"; then
        echo -e "${RED}Error: Base branch '$BASE_BRANCH' does not exist${NC}"
        return 1
    fi
    BRANCH_SOURCE="new branch from $BASE_BRANCH"
fi

# Show what will be created
echo -e "${BLUE}Creating worktree:${NC}"
echo "  Project:    $PROJECT_NAME"
echo "  Branch:     $BRANCH_NAME"
echo "  Source:     $BRANCH_SOURCE"
echo "  Directory:  $WORKTREE_DIR_NAME"
echo "  Path:       $WORKTREE_PATH"
echo ""

# Create worktrees directory if it doesn't exist
mkdir -p "$WORKTREES_DIR/$PROJECT_NAME"

# Create the worktree
case "$BRANCH_MODE" in
    existing-local)
        git worktree add "$WORKTREE_PATH" "$BRANCH_NAME"
        ;;
    existing-remote)
        git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "origin/$BRANCH_NAME"
        ;;
    new)
        git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "$BASE_BRANCH"
        ;;
esac

if [ $? -eq 0 ]; then
    echo ""
    echo -e "${GREEN}✓ Worktree created successfully!${NC}"

    # Copy dotfiles from the main repo to the new worktree. Iterate MAIN_ROOT so
    # dotfiles are always copied FROM the main checkout, regardless of where the
    # script was invoked (e.g. from inside another linked worktree).
    DOTFILES_COPIED=0
    for dotfile in "$MAIN_ROOT"/.*; do
        basename="$(basename "$dotfile")"
        # Skip ., .., .git, and any dotfile already present (tracked ones)
        if [[ "$basename" == "." || "$basename" == ".." || "$basename" == ".git" ]]; then
            continue
        fi
        cp -Rn "$dotfile" "$WORKTREE_PATH/"
        DOTFILES_COPIED=$((DOTFILES_COPIED + 1))
    done
    if [ $DOTFILES_COPIED -gt 0 ]; then
        echo -e "${GREEN}✓ Copied $DOTFILES_COPIED dotfile(s) to worktree${NC}"
    fi

    echo ""

    # Auto-cd if being sourced, otherwise provide instructions
    if [[ "${BASH_SOURCE[0]}" != "${0}" ]] || [[ -n "$ZSH_EVAL_CONTEXT" && "$ZSH_EVAL_CONTEXT" =~ :file$ ]]; then
        # Script is being sourced, we can change directory
        cd "$WORKTREE_PATH" || return 1
        echo -e "${GREEN}✓ Changed to worktree directory${NC}"
    else
        # Script is being executed, can't change parent shell directory
        echo -e "${BLUE}To change to the worktree directory, run:${NC}"
        echo "  cd $WORKTREE_PATH"
        echo ""
        echo -e "${YELLOW}Tip: For auto-cd, source the script instead:${NC}"
        echo "  source aa_g_worktree_init $FEATURE_NAME"
    fi

    echo ""
    echo -e "${BLUE}To remove this worktree later (from main repo):${NC}"
    echo "  aa_g_worktree_remove $FEATURE_NAME"
    if [[ "$FEATURE_NAME" == */* ]]; then
        echo "  or: aa_g_worktree_remove $WORKTREE_DIR_NAME"
    fi
else
    echo -e "${RED}Failed to create worktree${NC}"
    return 1
fi
